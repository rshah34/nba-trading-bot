# Postgres — read by BOTH docker-compose.yml and the app (config.py builds
# DATABASE_URL from these). Generate a password with: openssl rand -hex 24
POSTGRES_USER=nba_app
POSTGRES_PASSWORD=generate-a-strong-password
POSTGRES_DB=nba_bot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Claude API - https://console.anthropic.com/
ANTHROPIC_API_KEY=KEY

# Odds API - https://the-odds-api.com/ (free tier: 500 requests/month)
ODDS_API_KEY=KEY

# Voyage AI embeddings, used for news RAG - https://www.voyageai.com/ (free tier available)
VOYAGE_API_KEY=KEY

# Model selection
ANALYSIS_MODEL=claude-sonnet-5
EMBEDDING_MODEL=voyage-3
